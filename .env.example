# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: API key from https://resend.com (free tier available).
# Required for contact/internship/early-access form submissions to be
# emailed to you. Without it, submissions are only logged to the server
# console and are NOT delivered anywhere.
RESEND_API_KEY="re_your_api_key"

# NOTIFY_EMAIL: the inbox that receives every form submission.
NOTIFY_EMAIL="you@example.com"

# NOTIFY_FROM (optional): the "from" address on notification emails.
# Defaults to Resend's shared onboarding@resend.dev sender, which works
# without any domain setup. Verify your own domain in Resend to use a
# custom "from" address instead.
NOTIFY_FROM="Mashnu AI Website <onboarding@resend.dev>"

# Supabase project config, used by @supabase/server to verify users and
# run client/admin supabase-js calls from API handlers.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key"
SUPABASE_JWKS_URL="https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json"
# SUPABASE_SECRET_KEY: server-only secret, never expose client-side.
# Create/manage under Supabase dashboard > API Keys settings.
SUPABASE_SECRET_KEY="sb_secret_your_key"

# GROQ_API_KEY: API key from https://console.groq.com/keys. Powers the real
# AI Assistant chat responses (src/server/agentLogic.ts). Without it, the
# assistant falls back to a fixed "not configured" message.
GROQ_API_KEY="gsk_your_api_key"
